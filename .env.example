# PostgreSQL (pgvector) — docker-compose up -d postgres 로 실행
PG_URL=jdbc:postgresql://localhost:5432/ipo_vector
PG_USER=ipo
PG_PASSWORD=your_pg_password
PG_DB=ipo_vector

# MySQL — eclipse-backend의 eclipse_mysql 컨테이너 재사용 (port 3307)
MYSQL_URL=jdbc:mysql://localhost:3307/eclipse?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=UTF-8
MYSQL_USER=root
MYSQL_PASSWORD=eclipse123

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# RAG 파라미터 (로컬 테스트 시 완화)
RAG_SIMILARITY_THRESHOLD=0.3
RAG_MIN_NEWS_COUNT=3
RAG_SEARCH_WINDOW_DAYS=365
EMBEDDING_MIN_SUMMARY_LENGTH=50

# SQS (prod 프로파일에서만 사용, 로컬은 불필요)
SQS_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/496009355626/eclipse-ai-queue
